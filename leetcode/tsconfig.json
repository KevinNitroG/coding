{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node"],
    "module": "esnext",
    "lib": ["ES2024"],
    "alwaysStrict": true,
    "strictBindCallApply": true,
    "strictFunctionTypes": true,
    "target": "es2024",
    "isolatedModules": true
  },
  "include": ["./**/*.ts", "./**/*.js"]
}
